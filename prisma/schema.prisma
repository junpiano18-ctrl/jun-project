// 우리동네정치 / 정치인 지도 — Prisma schema
// Prisma 7.x + Supabase Postgres

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ──────────────────────────────────────────────────────────
// Enums
// ──────────────────────────────────────────────────────────

enum PositionType {
  NATIONAL_ASSEMBLY
  METRO_GOVERNOR
  LOCAL_GOVERNOR
  METRO_COUNCIL
  LOCAL_COUNCIL
  EDUCATION_SUPERINTENDENT
}

enum ElectedAs {
  CONSTITUENCY
  PROPORTIONAL
}

enum PoliticianTermStatus {
  ACTIVE     // 현직
  DISMISSED  // 의원직 상실
  SUSPENDED  // 직무정지
  DECEASED   // 사망
}

enum BillStatus {
  PENDING    // 심사 중 (계류) — PROC_RESULT null
  PASSED     // 통과 (원안가결/수정가결)
  REJECTED   // 처리 안 됨 (부결/폐기/철회/대안반영폐기/임기만료폐기)
}

// 본회의 표결 결과. nojepdqqaweusdfbi.RESULT_VOTE_MOD → 다음 enum.
//   "찬성" → AGREE, "반대" → DISAGREE, "기권" → ABSTAIN, "불참" → ABSENT
enum VoteResult {
  AGREE
  DISAGREE
  ABSTAIN
  ABSENT
}

// ──────────────────────────────────────────────────────────
// Reference data
// ──────────────────────────────────────────────────────────

model Party {
  id        String           @id @default(cuid())
  name      String           @unique
  shortName String?
  color     String
  terms     PoliticianTerm[]
}

model Term {
  id           String           @id @default(cuid())
  positionType PositionType
  number       Int
  startDate    DateTime
  endDate      DateTime
  terms        PoliticianTerm[]

  @@unique([positionType, number])
}

// ──────────────────────────────────────────────────────────
// Geography
// ──────────────────────────────────────────────────────────

model AdminRegion {
  code       String           @id
  name       String
  level      Int
  parentCode String?
  geometry   Json
  districts  DistrictRegion[]
}

model District {
  id             String           @id @default(cuid())
  positionType   PositionType
  name           String
  fullName       String
  isProportional Boolean          @default(false)
  centerLat      Float?
  centerLng      Float?
  regions        DistrictRegion[]
  terms          PoliticianTerm[]

  @@unique([positionType, name])
  @@index([positionType])
}

model DistrictRegion {
  districtId String
  regionCode String
  district   District    @relation(fields: [districtId], references: [id])
  region     AdminRegion @relation(fields: [regionCode], references: [code])

  @@id([districtId, regionCode])
}

// ──────────────────────────────────────────────────────────
// People
// ──────────────────────────────────────────────────────────

model Politician {
  id        String           @id @default(cuid())
  name      String
  hanjaName String?
  birthYear Int?
  gender    String?
  photoUrl  String?

  // 외부 시스템 ID — 출처별로 다르므로 수동 매핑 가능
  monaCd   String? @unique // 열린국회정보
  necId    String? @unique // 중앙선관위
  ethicsId String? @unique // 공직윤리시스템

  // 열린국회 의원 정보(nwvrqwxyaytdsfvhu)의 MEM_TITLE — 주요 학력·경력 통합 텍스트
  careerText String?

  terms       PoliticianTerm[]
  assets      Asset[]
  bills       Bill[]
  voteRecords VoteRecord[]

  @@index([name])
}

// 의원이 대표발의한 법안. 한 의원의 22대 임기 법안만 sync 대상.
model Bill {
  id           String     @id @default(cuid())
  billId       String     @unique // 열린국회 PRC_xxx 식 식별자
  politicianId String
  billName     String
  billStatus   BillStatus @default(PENDING)
  proposedAt   DateTime?
  billUrl      String
  summary      String?    // Claude API 쉬운 말 요약 (ANTHROPIC_API_KEY 생기면 채움)

  // 본회의 표결 집계 (sync-votes.ts가 본회의 처리안건 응답에서 update). 표결 없는 의안은 null.
  voteTcnt   Int? // 재석 총수
  yesTcnt    Int? // 찬성
  noTcnt     Int? // 반대
  blankTcnt  Int? // 기권

  politician Politician @relation(fields: [politicianId], references: [id])

  @@index([politicianId])
  @@index([proposedAt])
}

// 한 정치인의 한 임기 — 통계·공약·표결의 중심 단위
model PoliticianTerm {
  id            String    @id @default(cuid())
  politicianId  String
  termId        String
  districtId    String
  partyId       String?
  positionTitle String
  electedAs     ElectedAs
  electedDate   DateTime
  status        PoliticianTermStatus @default(ACTIVE)

  // 비싼 계산값 캐싱 — cron으로 갱신
  attendanceRate         Float?
  pledgeFulfillRate      Float?
  billProposedCount      Int?    // 대표발의 법안 수 (현 임기)
  billPassedCount        Int?    // 그중 본회의 가결 수
  plenaryVoteSessionCount Int?   // 현 임기 본회의 표결 총 횟수 (모수)
  plenaryVoteAttendCount  Int?   // 그중 참여 횟수
  committees             Json?   // 현 임기 위원회 이력 [{name, start, end}]

  // 본 직무 외 겸직 (예: 국회의원이 장관 겸직). 공직자만, 출처 명시 필요.
  additionalRole          String?
  additionalRoleStartDate DateTime?
  additionalRoleSource    String?

  // 법원 판결 정보. 수사·기소 단계는 표시 안 함 — 판결문(1심 이상)만 채울 것.
  // courtRulingFinal=true 이고 의원직 상실 효과가 발생한 경우 PoliticianTerm.status를
  // 별도로 DISMISSED로 set 해야 카드 빨간 배지가 뜸 (status enum이 master).
  courtRulingDate    DateTime?
  courtRulingSummary String?   // 예: "1심 징역 2년 선고"
  courtRulingFinal   Boolean?  // 확정 판결 여부 (대법원·상고 포기 등)
  courtRulingSource  String?   // 출처

  politician  Politician   @relation(fields: [politicianId], references: [id])
  term        Term         @relation(fields: [termId], references: [id])
  district    District     @relation(fields: [districtId], references: [id])
  party       Party?       @relation(fields: [partyId], references: [id])
  pledges     Pledge[]
  votes       Vote[]
  attendances Attendance[]

  @@unique([politicianId, termId])
  @@index([districtId])
  @@index([partyId])
}

// ──────────────────────────────────────────────────────────
// Content
// ──────────────────────────────────────────────────────────

model Pledge {
  id               String    @id @default(cuid())
  politicianTermId String
  category         String?
  title            String
  originalText     String
  easySummary      String? // Claude API로 생성한 중학생 눈높이 요약
  summaryModel     String?
  summaryUpdatedAt DateTime?
  status           String?

  politicianTerm PoliticianTerm @relation(fields: [politicianTermId], references: [id])

  @@index([politicianTermId])
}

model Asset {
  id           String   @id @default(cuid())
  politicianId String
  year         Int
  totalKrw     BigInt   // 현재가액 (천원 단위)
  changeKrw    BigInt?  // 증감액 (천원). 양수 증가, 음수 감소
  landKrw      BigInt?  // 토지
  buildingKrw  BigInt?  // 건물
  depositKrw   BigInt?  // 예금
  stockKrw     BigInt?  // 주식
  detail       Json?
  source       String
  disclosedAt  DateTime?

  politician Politician @relation(fields: [politicianId], references: [id])

  @@unique([politicianId, year])
}

model Vote {
  id               String   @id @default(cuid())
  politicianTermId String
  billId           String
  billName         String
  voteDate         DateTime
  result           String

  politicianTerm PoliticianTerm @relation(fields: [politicianTermId], references: [id])

  @@index([politicianTermId])
  @@index([billId])
}

model Attendance {
  id               String   @id @default(cuid())
  politicianTermId String
  date             DateTime
  sessionName      String
  status           String

  politicianTerm PoliticianTerm @relation(fields: [politicianTermId], references: [id])

  @@index([politicianTermId])
  @@index([date])
}

// 본회의 처리 안건 마스터 — VoteRecord의 billId가 가리키는 의안 메타.
// 발의 법안(Bill)이 아닌 대안·위원회안·예산안 등도 포함되므로 별도 모델.
// 소스: nwbpacrgavhjryiph + nbslryaradshbpbpm.
model PlenaryBill {
  billId    String    @id // 의안 식별자 (PRC_xxx)
  billName  String
  billUrl   String?
  age       Int       @default(22)
  procDate  DateTime?
  // 본회의 표결 집계
  voteTcnt  Int?
  yesTcnt   Int?
  noTcnt    Int?
  blankTcnt Int?
  // AI 요약 (Bill.summary와 동일한 system prompt, 향후 별도 sync)
  summary       String?
  summaryModel  String?
  summaryUpdatedAt DateTime?

  @@index([procDate])
}

// 본회의 표결 기록 — 한 의원의 한 의안에 대한 표결.
// 소스: 열린국회정보 nojepdqqaweusdfbi (의안 단위 호출, 의원당 row).
model VoteRecord {
  id           String     @id @default(cuid())
  politicianId String
  billId       String     // 의안 식별자 (PRC_xxx)
  billName     String
  voteDate     DateTime
  result       VoteResult
  billUrl      String?    // 의안정보시스템 링크
  sessionCd    Int?       // 회기 (예: 435)
  currentsCd   Int?       // 차수
  age          Int        // 국회 대수 (예: 22)

  politician Politician @relation(fields: [politicianId], references: [id])

  @@unique([politicianId, billId])
  @@index([politicianId, voteDate])
  @@index([billId])
}
